# Required: your Anthropic API key (https://console.anthropic.com/settings/keys)
ANTHROPIC_API_KEY=sk-ant-...

# Port for the local dashboard
PORT=4500

# Models. Defaults to Claude Opus 4.8 everywhere (best quality).
# Ranking is the high-volume step — if you want to cut cost, point RANK_MODEL
# at a cheaper model, e.g. claude-haiku-4-5 or claude-sonnet-4-6.
RANK_MODEL=claude-opus-4-8
WRITE_MODEL=claude-opus-4-8

# Optional: Adzuna (free tier) for location-based / non-remote coverage.
# Get credentials at https://developer.adzuna.com/ . Leave blank to skip.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
