# Job Hunter uses Google Gemini (free tier).
# You do NOT need this file at all — you can paste your key right in the web UI
# (⚙ Settings, top-right). Setting it here just pre-fills it for every visitor.

# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Default model (overridable per-request from the UI dropdown).
# Free + fast: gemini-2.5-flash. Higher quality: gemini-2.5-pro.
GEMINI_MODEL=gemini-2.5-flash

# Port for the local dashboard
PORT=4500

# Optional: Adzuna (free tier) for location-based / non-remote job coverage.
# Get credentials at https://developer.adzuna.com/ . Leave blank to skip.
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
ADZUNA_COUNTRY=gb
