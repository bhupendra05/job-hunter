# Job Hunter — environment variables
# You don't need this file at all for basic use. The Gemini key can be pasted
# right in the web UI (⚙ Settings, top-right). The job-board keys below are
# all OPTIONAL — each one unlocks an extra source. Leave blank to skip it.

# ── Gemini AI (required for ranking, cover letters, resume analysis) ─────────
# Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
# Default model. Free + fast: gemini-2.5-flash  |  Higher quality: gemini-2.5-pro
GEMINI_MODEL=gemini-2.5-flash

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4500

# ── Optional job sources (each adds a new board to your search) ───────────────

# JSearch via RapidAPI — aggregates LinkedIn, Indeed, Glassdoor, ZipRecruiter
# Best source for India-specific jobs (searches by city + country).
# Free tier: 500 requests/month. Register at https://rapidapi.com/letscrape-6bRB7pjs18l/api/jsearch
RAPIDAPI_KEY=

# USAJOBS — official U.S. federal government job board (free, official API)
# Required only if you want U.S. government / public sector roles.
# Register free at https://developer.usajobs.gov/ to get a key.
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# Adzuna — location-based / on-site job coverage (free tier)
# Get credentials at https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=
# Two-letter country code for Adzuna: gb, us, in, au, ca, de, fr, etc.
ADZUNA_COUNTRY=in
